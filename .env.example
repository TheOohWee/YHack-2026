# MongoDB Atlas — Connection string from Atlas UI (encode special chars in password).
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER_HOST.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=wattsup

# GridStatus.io hosted API (recommended for PJM fuel mix — avoids PJM Data Miner REST).
# Key: https://www.gridstatus.io/settings/api
GRIDSTATUS_API_KEY=your_gridstatus_io_api_key
# Optional: dataset id (default pjm_fuel_mix). Use miso_fuel_mix, etc. for other markets.
# GRIDSTATUS_IO_FUEL_DATASET=pjm_fuel_mix
# Cap rows per request (default 5000) to stay within plan limits.
# GRIDSTATUS_IO_ROW_LIMIT=5000

# PJM Data Miner API — only if you use open-source `gridstatus` PJM() instead of GridStatus.io.
# PJM_API_KEY=

# K2V2 / Lava — OpenAI-compatible gateway (Bearer token). Used by wattsup-poll / wattsup-worker.
# Code appends /v1/chat/completions to the base URL — use the host only, e.g. https://api.lava.so
# (not https://api.lava.so/v1/ or you will get /v1/v1/chat/completions).
# Aliases: LAVA_BASE_URL / LAVA_KEY are accepted instead of K2V2_BASE_URL / K2V2_API_KEY.
K2V2_BASE_URL=https://api.lava.so
K2V2_API_KEY=your_bearer_token_here
# LAVA_BASE_URL=https://your-lava-or-k2-host.example
# LAVA_KEY=your_bearer_token_here
# Model IDs are passed to the gateway as-is. Defaults are OpenAI-style (good for Lava).
# GEMINI_FLASH_MODEL=gpt-4o-mini
# GEMINI_PRO_MODEL=gpt-4o
# For a Gemini-native endpoint use e.g. gemini-2.0-flash / gemini-1.5-pro instead.

# Optional: skip gridstatusio PyPI version check on import.
# GSIO_SKIP_VERSION_CHECK=true

# Local HTTP server (wattsup-serve)
# WATTSUP_HOST=127.0.0.1
# WATTSUP_PORT=8000
