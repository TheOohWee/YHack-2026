# Copy to .env.local — mirrors Python wattsup/.env for Mongo
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=wattsup

# Default dashboard user (Mongo user_id on energy_logs / user_stats)
WATTSUP_DEFAULT_USER_ID=test-user

# Exposed to browser — optional default for the user id field
NEXT_PUBLIC_WATTSUP_USER_ID=test-user
